# --- App Settings ---
APP_NAME="Smart Voice Notes Assistant"
DEBUG=True
SECRET_KEY="your-super-secret-key-here" # Generate with: openssl rand -hex 32

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/voicenotes"

# --- Cache (Redis) ---
# Format: redis://host:port/db
REDIS_URL="redis://localhost:6379/0"

# --- Cloudflare R2 / S3 (Audio Storage) ---
S3_ENDPOINT_URL="https://<account-id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="your_access_key_id"
S3_SECRET_ACCESS_KEY="your_secret_access_key"
S3_BUCKET_NAME="voice-notes"
S3_PUBLIC_URL="https://your-bucket-public-url.com" # Optional, for serving files

# --- ML Settings ---
WHISPER_MODEL_SIZE="base"
WHISPER_DEVICE="cpu" # Use "cuda" if you have an NVIDIA GPU
TEMP_DIR="./tmp"
